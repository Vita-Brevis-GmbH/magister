# Magister reverse proxy.
#
# Auto-TLS via Let's-Encrypt; the public hostname and ACME email are passed
# as env from docker-compose. The Schweizer Schul-SPA is served by the
# magister-web container; the FastAPI backend lives behind the /api/* prefix
# and is mounted at "/" on the backend itself — Caddy strips /api/ on the
# way through (handle_path), so the backend stays prefix-agnostic.

{
    email {$MAGISTER_ACME_EMAIL}
    # Production defaults; uncomment for staging certs while testing:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$MAGISTER_PUBLIC_HOSTNAME} {
    encode zstd gzip

    # Security headers; Strict-Transport-Security is added by the auto-TLS
    # path automatically when the cert is in place.
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Tighten as the frontend takes shape (CSP needs the actual asset origins).
    }

    # Health-probes for ops — answered by the API directly, no /api/ prefix.
    handle /healthz {
        reverse_proxy magister-api:8000
    }

    # API + auth surface. handle_path strips the /api/ prefix before
    # forwarding — backend routers stay mounted at "/auth", "/classes",
    # "/users", "/students", "/admin", and don't need to know about Caddy.
    handle_path /api/* {
        reverse_proxy magister-api:8000 {
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Everything else is the SPA. magister-web (nginx:alpine) serves the
    # Vite bundle plus an index.html SPA fallback for client-side routes
    # like /classes, /users, /me — so a hard refresh still hits the SPA.
    handle {
        reverse_proxy magister-web:80
    }
}
