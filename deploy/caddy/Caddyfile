# Magister reverse proxy.
#
# TLS is ALWAYS self-signed via Caddy's built-in "internal" issuer — no ACME,
# no Let's-Encrypt, works fully offline behind an internal-only hostname. Caddy
# generates the certificate from its own local CA and stores it in the
# caddy_data volume; browsers show a one-time "untrusted certificate" warning
# that you accept manually.
#
# The Schweizer Schul-SPA is served by the magister-web container; the FastAPI
# backend lives behind the /api/* prefix and is mounted at "/" on the backend
# itself — Caddy strips /api/ on the way through (handle_path), so the backend
# stays prefix-agnostic.
#
# NOTE: HSTS is deliberately OMITTED. With a self-signed cert, an HSTS header
# would make the browser refuse the manual "accept the risk" bypass, locking you
# out of the site entirely. Do not add Strict-Transport-Security to this file.
{
	# When a client connects without SNI — e.g. access by IP address, where
	# browsers and curl omit the SNI extension — fall back to this name so
	# Caddy still serves the internal certificate instead of aborting the
	# handshake with a "tlsv1 alert internal error". Set MAGISTER_PUBLIC_HOSTNAME
	# to the exact host OR IP you reach the server by (e.g. 172.25.8.27), so the
	# certificate subject, the site match, and this default all line up.
	default_sni {$MAGISTER_PUBLIC_HOSTNAME}
}

# HTTPS-only: every plain-HTTP request is permanently redirected to its
# HTTPS equivalent (Host + path preserved). No application content is ever
# served over cleartext. This explicit catch-all replaces Caddy's implicit
# per-host redirect, so it also covers access by IP or an unexpected Host
# header — anything that hits :80 bounces to :443. HSTS stays OFF (see the
# header note below) — the redirect is enough and does not lock out the
# one-time self-signed-cert acceptance.
http:// {
	redir https://{host}{uri} permanent
}

(security_headers) {
	header {
		# MIME-sniff lock-down + clickjacking + referrer minimisation.
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"

		# Disable powerful platform APIs the SPA does not use. Listed
		# explicitly so a future dep that quietly adopts one fails loud.
		Permissions-Policy "accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), cross-origin-isolated=(), display-capture=(), document-domain=(), encrypted-media=(), execution-while-not-rendered=(), execution-while-out-of-viewport=(), fullscreen=(self), geolocation=(), gyroscope=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), navigation-override=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=(), interest-cohort=()"

		# Cross-Origin isolation. Magister is strictly same-origin; no
		# external embeds (CDN images, fonts, iframes). `require-corp` will
		# therefore not break the SPA, and it removes the legacy fallback
		# paths that Spectre-style side-channels exploit.
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Embedder-Policy "require-corp"
		Cross-Origin-Resource-Policy "same-origin"

		# Content-Security-Policy. The SPA is fully self-hosted, so the
		# baseline is `'self'` everywhere with three concessions:
		#   - `img-src data:` for inline favicons / SVG data URLs.
		#   - `style-src 'unsafe-inline'` because Radix UI / shadcn-ui
		#     attach dynamic `<style>` tags for positioning (popover,
		#     dialog overlay). Inline-style attributes via React `style`
		#     props are NOT covered by style-src, so this only affects
		#     Radix's portal-managed elements.
		#   - `connect-src 'self'` keeps the API + auth surface on the
		#     same origin (Caddy fronts both behind /api/*).
		Content-Security-Policy "default-src 'self'; script-src 'self'; script-src-elem 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none'; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests"

		# Strip the Server header so the reverse-proxy version is not
		# advertised. nginx behind us already does `server_tokens off`.
		-Server
	}
}

{$MAGISTER_PUBLIC_HOSTNAME} {
	# TLS is driven by a snippet the API materializes into the shared
	# /certs volume: `tls /certs/tls.pem /certs/tls.key` when an admin has
	# imported a real certificate (Einstellungen → System), otherwise
	# `tls internal` (Caddy's self-signed internal CA — no ACME, offline).
	# The API always writes this file on startup, and the caddy container
	# waits for it before booting, so the import never fails.
	import /certs/tls.caddy

	encode zstd gzip

	import security_headers

	# Health-probes for ops — answered by the API directly, no /api/ prefix.
	handle /healthz {
		reverse_proxy magister-api:8000
	}

	# API + auth surface. handle_path strips the /api/ prefix before
	# forwarding — backend routers stay mounted at "/auth", "/classes",
	# "/users", "/students", "/teachers", "/admin", and don't need to know
	# about Caddy.
	handle_path /api/* {
		reverse_proxy magister-api:8000 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Everything else is the SPA. magister-web (nginx:alpine) serves the
	# Vite bundle plus an index.html SPA fallback for client-side routes
	# like /classes, /users, /me — so a hard refresh still hits the SPA.
	handle {
		reverse_proxy magister-web:80
	}
}
