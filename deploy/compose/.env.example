# Magister Compose-Stack — copy to `.env` and fill in.
# All MAGISTER_*-keys are read by pydantic-settings inside the API container.

# --- Compose stack: networking + image -------------------------------------
# Public FQDN or IP of this Magister instance — used for Caddy's self-signed
# certificate subject (internal CA, no ACME) + the OIDC redirect URI. Set it to
# the exact host OR IP you reach the server by so the cert subject lines up.
MAGISTER_PUBLIC_HOSTNAME=magister.example.ch
# Override to pin to a release tag; defaults to ":latest" (auto-tracked).
# MAGISTER_API_IMAGE=ghcr.io/vita-brevis-gmbh/magister-api:v0.2.0
# MAGISTER_WEB_IMAGE=ghcr.io/vita-brevis-gmbh/magister-web:v0.2.0

# --- Core --------------------------------------------------------------------
MAGISTER_LOG_LEVEL=INFO

# --- Database ----------------------------------------------------------------
# Postgres bootstrap — only the password field needs to be filled in;
# the API container reads MAGISTER_DATABASE_URL constructed from these.
POSTGRES_USER=magister
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=magister

# --- Crypto / sessions -------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# AUDIT_KEY: do NOT rotate without a key-rotation migration; existing audit
# rows encrypted with the old key would otherwise become unreadable.
MAGISTER_AUDIT_KEY=CHANGE_ME_AUDIT_KEY
# Optional: dedicated key for the app_settings secrets (OIDC client secret,
# AD bind password) instead of reusing AUDIT_KEY. Leave empty to reuse AUDIT_KEY
# (current behaviour). If you set a distinct value, re-enter those two secrets
# once in the admin UI so they get re-encrypted with the new key.
MAGISTER_SECRETS_KEY=
MAGISTER_SESSION_SECRET=CHANGE_ME_SESSION_SECRET
MAGISTER_CSRF_SECRET=CHANGE_ME_CSRF_SECRET

# --- OIDC against Entra ID ---------------------------------------------------
# As of M1.5 the OIDC config moved into the DB-backed `app_settings` row and
# is editable via the admin GUI. These env vars are seeded ONCE on first
# boot if the row is empty; afterwards the DB is authoritative and the env
# vars can be removed.
MAGISTER_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
MAGISTER_OIDC_CLIENT_ID=
MAGISTER_OIDC_CLIENT_SECRET=

# --- Bootstrap admins (comma-separated UPNs) --------------------------------
# Granted role=admin on first OIDC login. Remove from .env once persisted.
MAGISTER_BOOTSTRAP_ADMINS=admin1@example.ch

# --- Local break-glass admin (used when OIDC isn't configured / available) --
# Single account; only consulted on the first boot when local_admins is empty.
# Pass a pre-computed argon2id hash, NEVER plaintext. Easiest: let the installer
# do it (scripts/install-magister.sh). To generate one by hand, either:
#   - from a repo checkout:  cd apps/api && uv run ../../scripts/magister-cli hash-password
#   - from the image only:   printf '%s' 'YOUR_PASSWORD' | docker run --rm -i \
#       --entrypoint python ghcr.io/vita-brevis-gmbh/magister-api:latest \
#       -c 'import sys; from magister_api.auth.passwords import hash_password; print(hash_password(sys.stdin.readline().rstrip("\n")))'
#
# CRITICAL — escaping: an argon2id hash contains '$', and docker compose
# interpolates '$' in .env values. You MUST double every '$' to '$$' here,
# otherwise the hash arrives corrupted and login fails silently. Example:
#   $argon2id$v=19$...  ->  $$argon2id$$v=19$$...
# (The installer handles this for you.)
#
# After the first boot the row is in the DB and these env vars can be removed.
MAGISTER_LOCAL_ADMIN_USERNAME=admin
# MAGISTER_LOCAL_ADMIN_PASSWORD_HASH=$$argon2id$$v=19$$m=65536,t=3,p=4$$...

# --- AD --------------------------------------------------------------------
# Like the OIDC config above, AD settings now live in the DB and are
# editable via the admin GUI. These env vars are seeded ONCE on first
# boot if the `app_settings` row is empty.
MAGISTER_AD_DCS=dc1.example.local,dc2.example.local
# Service-account bind mode:
#   simple  (default) — MAGISTER_AD_BIND_DN + MAGISTER_AD_BIND_PASSWORD over LDAPS.
#   gssapi           — Kerberos/keytab, NO password stored. Leave BIND_DN/PASSWORD
#                      empty and follow docs/runbooks/ad-gssapi-bind.md.
MAGISTER_AD_BIND_MODE=simple
MAGISTER_AD_BIND_DN=
MAGISTER_AD_BIND_PASSWORD=
# Subtree walked by the user-sync. Each user's school is derived from
# matching schools.scope_short against the OU path.
MAGISTER_AD_USERS_SEARCH_BASE=OU=Users,DC=example,DC=local
# Drives the in-process periodic AD sync (background task started by the API
# lifespan). GUI-editable at runtime; the manual /admin/ad-sync trigger stays
# available for on-demand syncs.
MAGISTER_AD_SYNC_INTERVAL_MINUTES=15
# Optional: pin the LDAPS trust anchor to an internal CA bundle. When set,
# the path must be readable inside the magister-api container — mount the
# bundle as a volume in docker-compose.yml. Unset = use the OS trust store.
# MAGISTER_AD_CA_BUNDLE_PATH=/etc/magister/ad-ca-bundle.pem

# --- System ops (WebUI restart/update) ---------------------------------------
# Host directory shared with the ops-agent for WebUI-triggered restart/update
# (Einstellungen → System). The API writes request files here; a host systemd
# watcher executes them. See docs/runbooks/system-updates.md. Defaults to ./ops
# next to this compose file; leave unset to disable the restart/update controls
# only by also removing the /ops mount.
# MAGISTER_OPS_HOST_DIR=/opt/magister/ops

# --- Backups -----------------------------------------------------------------
# Cron schedule for the pg-backup sidecar (system-cron syntax).
BACKUP_CRON=15 2 * * *
BACKUP_RETENTION_DAYS=14

