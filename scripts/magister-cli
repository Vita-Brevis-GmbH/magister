#!/usr/bin/env python3
"""Magister CLI — small ops tool for things you can't (yet) do via the API.

Usage:
    magister-cli hash-password           # reads password from stdin (no echo)
    magister-cli hash-password --plain   # reads password from stdin (shown)

Designed to run from the apps/api/.venv (so argon2-cffi is available):

    cd apps/api
    uv run ../../scripts/magister-cli hash-password
"""

from __future__ import annotations

import argparse
import getpass
import sys


def cmd_hash_password(args: argparse.Namespace) -> int:
    try:
        from magister_api.auth.passwords import hash_password
    except ImportError:
        sys.stderr.write(
            "magister_api is not importable — run inside apps/api's venv:\n"
            "  cd apps/api && uv run ../../scripts/magister-cli hash-password\n"
        )
        return 2

    if args.plain:
        sys.stderr.write("Password: ")
        sys.stderr.flush()
        password = sys.stdin.readline().rstrip("\n")
    else:
        password = getpass.getpass("Password: ")
        confirm = getpass.getpass("Confirm:  ")
        if password != confirm:
            sys.stderr.write("Passwords do not match.\n")
            return 1

    if len(password) < 12:
        sys.stderr.write(
            "Refusing to hash a password under 12 characters — "
            "set a stronger one for an admin break-glass account.\n"
        )
        return 1

    sys.stdout.write(hash_password(password) + "\n")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="magister-cli", description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=True)

    hp = sub.add_parser(
        "hash-password",
        help="Read a password and print its argon2id hash for "
        "MAGISTER_LOCAL_ADMIN_PASSWORD_HASH.",
    )
    hp.add_argument(
        "--plain",
        action="store_true",
        help="Read from stdin without prompting (e.g. for piping). The "
        "password is NOT echoed back.",
    )
    hp.set_defaults(func=cmd_hash_password)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
